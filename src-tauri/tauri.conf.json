{
  "$schema": "https://raw.githubusercontent.com/nicktomyang/tauri-apps/tauri-v2/crates/tauri-cli/schema.json",
  "productName": "Dagashi",
  "version": "0.1.0",
  "identifier": "com.dagashi.desktop",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "bundle": {
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128@2x.png"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Dagashi",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  }
}
