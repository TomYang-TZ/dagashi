{
  "identifier": "default",
  "description": "Default capability for Dagashi",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-start-dragging",
    "core:event:default",
    {
      "identifier": "core:app:default"
    }
  ],
  "remote": {
    "urls": ["*"]
  }
}
